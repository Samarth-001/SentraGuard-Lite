# --- API (app/main.py, app/config.py) ---
POLICY_PATH=policy.yaml
PORT=8000

# --- Streamlit UI (streamlit_app.py) ---
# Base URL the Streamlit app uses to reach the API (also editable live in
# the sidebar). For local (non-Docker) runs, http://localhost:8000 is
# correct. Under docker compose, this must be http://api:8000 -- that's
# already set correctly inside docker-compose.yml itself, this value
# here is only the default for running `streamlit run` directly.
SENTRAGUARD_API_URL=http://localhost:8000

# --- CLI (cli.py, step 8 -- not yet built) ---
# Recommend reusing SENTRAGUARD_API_URL for consistency once cli.py exists,
# rather than introducing a second env var name for the same concept.
